{
  "script": [
    { "url": "https://cdn.jsdelivr.net/npm/mermaid@11.14.0/dist/mermaid.min.js" },
    { "content": "document.querySelectorAll('pre code.language-mermaid').forEach(function(el){var div=document.createElement('div');div.className='mermaid';div.textContent=el.textContent;el.closest('pre').replaceWith(div);});mermaid.initialize({startOnLoad:false,theme:'neutral'});mermaid.run({querySelector:'.mermaid'});" }
  ],
  "pdf_options": {
    "format": "A4",
    "margin": { "top": "20mm", "bottom": "20mm", "left": "20mm", "right": "20mm" },
    "printBackground": true
  }
}
